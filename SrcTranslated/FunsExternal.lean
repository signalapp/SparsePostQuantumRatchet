axiom libcrux_hmac.hmac_sha256_tag32_spec
    (key data : Slice U8)
    (hkey : key.length ≤ U32.max)
    (hdata : data.length ≤ U32.max) :
    libcrux_hmac.hmac .Sha256 key data (some 32#usize)
      ⦃ (r : alloc.vec.Vec U8) =>
        libcrux_hmac.hmac .Sha256 key data (some 32#usize) = ok r ∧
        r.length = 32 ⦄

